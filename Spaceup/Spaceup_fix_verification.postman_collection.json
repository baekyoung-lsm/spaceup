{
	"info": {
		"_postman_id": "b7e1a2b0-1c2d-4e3f-9a1b-spaceup000001",
		"name": "Spaceup - 수정사항 검증 (build.gradle / Notification / Request)",
		"description": "이번에 고친 3가지를 실제 API 호출로 확인하는 컬렉션입니다.\n1. build.gradle -parameters 옵션 → @PathVariable 이름 자동 바인딩 (의뢰 상세 조회 등에서 확인)\n2. Notification.read → is_read 컬럼명 매핑 (알림 목록/읽음처리에서 확인)\n3. Request.requestCode nullable=false 제거 → 의뢰 생성 시 첫 INSERT가 제약조건 위반 없이 성공하는지 확인\n\n순서대로 실행(Run collection)하면 됩니다. 회원가입 요청의 Pre-request Script가 매번 새 아이디를 생성하므로 재실행해도 중복 에러 없이 돌아갑니다.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "base_url", "value": "http://localhost:8087", "type": "string" },
		{ "key": "username", "value": "", "type": "string" },
		{ "key": "password", "value": "Test1234!", "type": "string" },
		{ "key": "token", "value": "", "type": "string" },
		{ "key": "requestId", "value": "", "type": "string" }
	],
	"item": [
		{
			"name": "1. 회원가입 (임대인)",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.collectionVariables.set('username', 'tester_' + Date.now());"
						]
					}
				},
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('회원가입 성공 (200, success=true)', function () {",
							"    pm.response.to.have.status(200);",
							"    pm.expect(pm.response.json().success).to.eql(true);",
							"});"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [ { "key": "Content-Type", "value": "application/json" } ],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"role\": \"LANDLORD\",\n    \"username\": \"{{username}}\",\n    \"password\": \"{{password}}\",\n    \"email\": \"{{username}}@example.com\",\n    \"name\": \"테스터\",\n    \"phoneNumber\": \"010-1234-5678\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/member/join",
					"host": [ "{{base_url}}" ],
					"path": [ "api", "member", "join" ]
				}
			}
		},
		{
			"name": "2. 로그인",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('로그인 성공 및 토큰 발급', function () {",
							"    pm.response.to.have.status(200);",
							"    var data = pm.response.json();",
							"    pm.expect(data.success).to.eql(true);",
							"    pm.expect(data.data).to.be.a('string').and.not.empty;",
							"    pm.collectionVariables.set('token', data.data);",
							"});"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [ { "key": "Content-Type", "value": "application/json" } ],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"username\": \"{{username}}\",\n    \"password\": \"{{password}}\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/member/login",
					"host": [ "{{base_url}}" ],
					"path": [ "api", "member", "login" ]
				}
			}
		},
		{
			"name": "3. 의뢰 생성 (requestCode nullable 수정 확인)",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('의뢰 생성 성공 - 첫 INSERT 시점에 requestCode가 null이어도 제약조건 위반 없이 저장됨', function () {",
							"    pm.response.to.have.status(200);",
							"    var data = pm.response.json();",
							"    pm.expect(data.success).to.eql(true);",
							"    pm.expect(data.data).to.be.a('number');",
							"    pm.collectionVariables.set('requestId', data.data);",
							"});"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" },
					{ "key": "Authorization", "value": "Bearer {{token}}" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"region\": \"광주 북구\",\n    \"propertyType\": \"아파트\",\n    \"areaM2\": 84.5,\n    \"deposit\": 5000000,\n    \"monthlyRent\": 500000,\n    \"targetRent\": 400000,\n    \"budgetMin\": 3000000,\n    \"budgetMax\": 5000000,\n    \"desiredDate\": \"2026-08-15\",\n    \"requestedItems\": \"도배,장판,조명\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/requests",
					"host": [ "{{base_url}}" ],
					"path": [ "api", "requests" ]
				}
			}
		},
		{
			"name": "4. 의뢰 상세 조회 (-parameters 옵션 / @PathVariable 바인딩 확인)",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('PathVariable requestId 정상 바인딩 (400 Name for argument 에러가 아니어야 함)', function () {",
							"    pm.response.to.have.status(200);",
							"    var data = pm.response.json();",
							"    pm.expect(data.success).to.eql(true);",
							"    pm.expect(String(data.data.id)).to.eql(String(pm.collectionVariables.get('requestId')));",
							"});",
							"",
							"pm.test('requestCode가 실제로 채워졌는지 확인 (assignCode 동작)', function () {",
							"    var data = pm.response.json().data;",
							"    pm.expect(data.requestCode).to.be.a('string').and.not.empty;",
							"});"
						]
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
				"url": {
					"raw": "{{base_url}}/api/requests/{{requestId}}",
					"host": [ "{{base_url}}" ],
					"path": [ "api", "requests", "{{requestId}}" ]
				}
			}
		},
		{
			"name": "5. 내 알림 목록 조회 (is_read 컬럼 매핑 확인)",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('notifications 테이블 조회 성공 (READ 예약어 충돌 없음)', function () {",
							"    pm.response.to.have.status(200);",
							"    pm.expect(pm.response.json().success).to.eql(true);",
							"});"
						]
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
				"url": {
					"raw": "{{base_url}}/api/notifications/me",
					"host": [ "{{base_url}}" ],
					"path": [ "api", "notifications", "me" ]
				}
			}
		},
		{
			"name": "6. 모든 알림 읽음 처리 (is_read UPDATE 쿼리 확인)",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('is_read 컬럼 UPDATE 쿼리 정상 동작', function () {",
							"    pm.response.to.have.status(200);",
							"    pm.expect(pm.response.json().success).to.eql(true);",
							"});"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
				"url": {
					"raw": "{{base_url}}/api/notifications/read-all",
					"host": [ "{{base_url}}" ],
					"path": [ "api", "notifications", "read-all" ]
				}
			}
		}
	]
}
